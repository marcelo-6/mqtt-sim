# run this from the root of the repo btw
Output docs/images/simulator-running.gif

Set TypingSpeed 75ms
Set FontSize 22
Set Width 1500
Set Height 650

# Type a command in the terminal.
Type 'uv run mqtt-sim run -c "examples/basic.toml"'

# Pause for dramatic effect...
Sleep 500ms

# Run the command by pressing enter.
Enter

# Admire the output for a bit.
Sleep 5s

# Stop the process.
Ctrl+C
